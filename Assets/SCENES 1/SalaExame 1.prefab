  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TextoAnimado
  textoCompleto: "Cheg\xE1mos ao fim da nossa simula\xE7\xE3o. Muito obrigada por
    teres participado e testado o SereneFlow. Espero que o facto de teres vivido
    esta experi\xEAncia, num ambiente seguro e controlado, te ajude a enfrentar o
    dia do teu exame real com muito mais confian\xE7a e tranquilidade. Quando te
    sentires pronto, podes retirar os teus comandos e os \xF3culos de Realidade Virtual.
    Um excelente resto de dia para ti!"
  velocidadeMinima: 15
  velocidadeMaxima: 40
  pausaEntreFrases: 0.1
  maxLinhas: 3
