  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Cheg\xE1mos \xE0 sala onde vai decorrer a simula\xE7\xE3o do exame. Os
    dois maiores receios associados a este exame s\xE3o o barulho da m\xE1quina e
    o espa\xE7o mais reduzido \u2014 mas vou explicar-te porque n\xE3o precisas de
    te preocupar. O barulho que vais ouvir \xE9 simplesmente a eletricidade a ativar
    e desativar os \xEDmanes que tiram as imagens, fazendo as pe\xE7as internas vibrarem
    em seguran\xE7a. Esses \xEDmanes funcionam como o foco de uma c\xE2mara muito
    avan\xE7ada, a criar um mapa detalhado do teu corpo. Depois, uma onda de r\xE1dio
    completamente inofensiva capta a imagem \u2014 como um flash invis\xEDvel. E
    no exame real v\xE3o dar-te auscultadores para abafar o som! Quanto ao espa\xE7o,
    lembra-te sempre: a m\xE1quina \xE9 aberta nas duas pontas, o ar circula constantemente,
    e nunca est\xE1s sozinho \u2014 a equipa m\xE9dica est\xE1 sempre a acompanhar-te.
    Para ouvires o som da m\xE1quina e passarmos \xE0 \xFAltima explica\xE7\xE3o,
    olha para a esfera durante tr\xEAs segundos!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
