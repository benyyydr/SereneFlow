  m_Script: {fileID: 11500000, guid: 03ac19911da6b0a4780575b6f3a4c528, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TextoAnimado
  textoCompleto: "Ol\xE1, bem-vindo ao SereneFlow. Hoje est\xE1s aqui para viveres
    a simula\xE7\xE3o de uma Resson\xE2ncia Magn\xE9tica, guiada por mim, com exerc\xEDcios
    para te manteres mais calmo no dia do exame real.\r\nPodes deslocar-te livremente
    para explorar o local e quando te sentires confort\xE1vel para teleportares para
    a sala de espera, \xE9 s\xF3 apontares o comando para a esfera e clicares no
    bot\xE3o lateral! \r\n"
  velocidadeMinima: 18
  velocidadeMaxima: 40
  pausaEntreFrases: 0.2
  maxLinhas: 3
