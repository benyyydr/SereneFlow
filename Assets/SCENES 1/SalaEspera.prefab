  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TextoAnimado
  textoCompleto: "\xD3timo! Agora que j\xE1 sabes como te deslocar, vou explicar-te
    o que \xE9 uma Resson\xE2ncia Magn\xE9tica. \xC9 um exame de diagn\xF3stico m\xE9dico,
    seguro e n\xE3o invasivo, que utiliza um campo magn\xE9tico e ondas de r\xE1dio
    para criar imagens detalhadas dos \xF3rg\xE3os e tecidos do teu corpo. Para conheceres
    melhor a sala onde o exame vai acontecer, aponta para a porta azul e clica!"
  velocidadeMinima: 15
  velocidadeMaxima: 40
  pausaEntreFrases: 0.1
  maxLinhas: 3
